{
  "extends": "@noro/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@noro-types/*": [
        "../../packages/types/*"
      ],
      "@noro/ui/*": [
        "../../packages/ui/*"
      ],
      "@noro/lib/*": [
        "../../packages/lib/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}