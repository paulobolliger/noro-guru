{
  "extends": "@noro/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@noro/ui/*": [
        "../../packages/ui/*"
      ],
      "@noro/lib/*": [
        "../../packages/lib/*"
      ],
      "@noro/types/*": [
        "../../packages/types/*"
      ],
      "@noro-types/*": [
        "../../packages/types/*"
      ]
    },
    "strictNullChecks": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.mjs",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}