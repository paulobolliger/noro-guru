{
  "extends": "@noro/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@noro/ui": [
        "../../packages/ui/src"
      ],
      "@noro/lib": [
        "../../packages/lib/src"
      ],
      "@noro/types": [
        "../../packages/types/src"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}