{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@noro/ui": [
        "../../packages/ui"
      ],
      "@noro/ui/*": [
        "../../packages/ui/*"
      ],
      "@noro/lib": [
        "../../packages/lib"
      ],
      "@noro/lib/*": [
        "../../packages/lib/*"
      ],
      "@noro/types": [
        "../../packages/types"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../../node_modules"
  ]
}
