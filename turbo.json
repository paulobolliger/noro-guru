{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "GEMINI_API_KEY",
    "NEXT_PUBLIC_CORE_URL",
    "NEXT_PUBLIC_CONTROL_URL",
    "ALLOWED_ORIGINS",
    "OPENAI_API_KEY",
    "RESEND_API_KEY",
    "RAPIDAPI_KEY",
    "NEXT_PUBLIC_CLIENT_ID",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "CONTROL_PLANE_API_KEY",
    "SUPPORT_FUNCTION_SECRET",
    "DATABASE_URL",
    "DIRECT_DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET",
    "DIRECTUS_URL",
    "DIRECTUS_TOKEN",
    "LOGTO_ENDPOINT",
    "LOGTO_APP_ID",
    "LOGTO_APP_SECRET",
    "LOGTO_COOKIE_SECRET",
    "NEXT_PUBLIC_LOGTO_ENDPOINT",
    "ASAAS_API_KEY",
    "ASAAS_SANDBOX",
    "ASAAS_PLATFORM_WALLET_ID",
    "STRIPE_SECRET_KEY",
    "CIELO_MERCHANT_ID",
    "CIELO_MERCHANT_KEY",
    "CONTROL_PLANE_URL",
    "EREDE_SANDBOX",
    "EREDE_CLIENT_ID",
    "EREDE_CLIENT_SECRET",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": [
        "build"
      ]
    },
    "lint": {},
    "test": {
      "outputs": [
        "coverage/**"
      ],
      "dependsOn": []
    }
  }
}
