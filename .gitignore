# =====================================================
# 🌐 NOMADE GURU | NORO | CONTROL | SAFETrip | Vistos
# Gitignore otimizado para monorepo com Next.js, Worker,
# Supabase, Railway e Vercel.
# =====================================================

# ==============================
# ⚙️ Node & Package Managers
# ==============================
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================
# 🧱 Build / Output / Caches
# ==============================
**/.next/
out/
dist/
build/
.cache/
.vercel/
.vercel_build_output/
.tmp/
temp/

# ==============================
# 🧪 Testing & Coverage
# ==============================
coverage/
*.lcov
*.spec.ts
*.test.ts

# ==============================
# 💾 Databases & Logs
# ==============================
*.sqlite
*.db
*.log
logs/
*.pid
*.seed
.dump
pgdata/
dbdata/

# ==============================
# ☁️ Cloud / Hosting
# ==============================
.railway/
.docker/
docker-compose.override.yml
Dockerfile.local
*.tar
*.gz

# ==============================
# 🌍 Environment Variables
# ==============================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ==============================
# 🧠 Supabase / Config
# ==============================
supabase/.branches/
supabase/.temp/
supabase/functions/.output/
supabase/.studio/
supabase/migrations/.temp/
supabase/.env
supabase/.cache/
supabase/.local/
supabase/.history/

# ==============================
# 💻 IDE / Editor / OS files
# ==============================
.vscode/
.vscode/mcp.local.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# ==============================
# 🔐 Certificates / Keys / Secrets
# ==============================
*.pem
*.key
*.crt
*.p12
*.cert
*.csr

# ==============================
# 📦 Monorepo Workspace Output
# ==============================
apps/**/.next/
apps/**/out/
apps/**/dist/
apps/**/.vercel/
apps/**/coverage/
apps/**/.env*
packages/**/dist/
packages/**/build/
packages/**/.env*

# ==============================
# 🧰 Misc
# ==============================
*.tmp
*.bak
*.old
*.orig
*.rej
*.cache
*.map
npm-debug.log*
yarn-debug.log*
lerna-debug.log*

# Diretório de scripts de migração local
/migracao-bd/

# =====================================================
# ==============================
# Local / Windows reserved files
# Evita problemas com arquivos temporários e nomes reservados no Windows
CON

# Turbo daemon logs (gerados localmente, não enviar ao repositório)
.turbo/daemon/
.turbo/

# Arquivos CSV de export/metadata grandes gerados localmente - não versionar
# Ex: Supabase Snippet Column Metadata with Primary & Foreign Key Details (1).csv
"Supabase Snippet Column Metadata with Primary & Foreign Key Details (1).csv"

# ✅ Fim do .gitignore
# =====================================================
